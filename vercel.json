{
  "version": 2,
  "builds": [
    {
      "src": "landing/index.html",
      "use": "@vercel/static"
    },
    {
      "src": "home/index.html",
      "use": "@vercel/static"
    },
    {
      "src": "contact.html",
      "use": "@vercel/static"
    },
    {
      "src": "privacy.html",
      "use": "@vercel/static"
    },
    {
      "src": "terms.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "^/$",
      "dest": "/landing/index.html"
    },
    {
      "src": "^/landing$",
      "dest": "/landing/index.html"
    },
    {
      "src": "^/landing/$",
      "dest": "/landing/index.html"
    },
    {
      "src": "^/home$",
      "dest": "/home/index.html"
    },
    {
      "src": "^/home/$",
      "dest": "/home/index.html"
    },
    {
      "src": "^/contact$",
      "dest": "/contact.html"
    },
    {
      "src": "^/contact/$",
      "dest": "/contact.html"
    },
    {
      "src": "^/privacy$",
      "dest": "/privacy.html"
    },
    {
      "src": "^/privacy/$",
      "dest": "/privacy.html"
    },
    {
      "src": "^/terms$",
      "dest": "/terms.html"
    },
    {
      "src": "^/terms/$",
      "dest": "/terms.html"
    },
    {
      "src": "^/(.*)$",
      "dest": "/landing/index.html"
    }
  ],
  "env": {

  },
  "functions": {

  },
  "framework": null
}
